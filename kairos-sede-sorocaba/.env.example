# Banco de dados
POSTGRES_PASSWORD=senha-segura-aqui

# Segurança
SECRET_KEY=gere-uma-chave-aleatoria-segura

# Kairos Admin
KAIROS_ADMIN_URL=https://api.admin.fbautomacao.space
KAIROS_CLIENT_ID=cole-o-uuid-do-cliente-aqui

# Admin inicial (criado automaticamente no primeiro start, login via Google)
ADMIN_EMAIL=admin@obpcsorocaba.com.br

# Login com Google (OAuth2)
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_REDIRECT_URI=https://api.sede.fbautomacao.space/api/auth/google/callback

# URL pública do frontend, para onde o backend redireciona após o login
FRONTEND_URL=https://sede.fbautomacao.space

# CORS (separar por vírgula)
CORS_ORIGINS=https://sede.fbautomacao.space,https://www.sede.fbautomacao.space

# ── LGPD ────────────────────────────────────────────────────────────────────
# Versão do termo — bump a cada alteração legal → reaceite automático
LGPD_VERSAO_TERMO=1.0.0
# E-mail do Encarregado de dados (DPO) — exibido nas páginas legais
LGPD_DPO_EMAIL=dpo@obpcsorocaba.com.br
# Prazo de retenção em meses (informativo, exibido na política)
LGPD_RETENCAO_MESES=60
# Controladora (igreja) — exibida na política e termos
LGPD_CONTROLADORA_NOME=OBPC Sorocaba
LGPD_CONTROLADORA_CNPJ=
LGPD_CONTROLADORA_ENDERECO=
