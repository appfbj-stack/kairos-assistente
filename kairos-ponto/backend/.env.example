# ===== Banco de dados PRÓPRIO do Kairos Ponto (separado do Kairos Admin) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kairos_ponto
POSTGRES_USER=kairos_ponto
POSTGRES_PASSWORD=troque-esta-senha
# Alternativamente, uma URL completa (tem prioridade sobre as variáveis acima)
# DATABASE_URL=postgresql://kairos_ponto:senha@postgres:5432/kairos_ponto

# ===== Segurança =====
PONTO_JWT_SECRET=troque-esta-chave-secreta-bem-grande
PORT=8040

# ===== Bootstrap do SUPER_ADMIN inicial =====
SUPER_ADMIN_EMAIL=admin@kairosponto.com
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Admin

# ===== Integração com o Kairos Admin (licenciamento centralizado) =====
# URL do Kairos Admin (hub central de licenças)
KAIROS_ADMIN_URL=http://kairos-backend:3010
# Slug deste app registrado no Kairos Admin
KAIROS_APP_SLUG=kairos-ponto
# UUID do cliente no Kairos Admin (preenchido por empresa via painel, opcional global)
KAIROS_CLIENT_ID=
# fail-open: se o Kairos Admin estiver inacessível, libera acesso (true) ou bloqueia (false)
LICENSE_FAIL_OPEN=true

# ===== IA Kairos (OpenRouter / OpenAI compatível) =====
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# ===== Reconhecimento facial =====
# none = armazena selfies e marca para revisão manual (padrão, sem dependências externas)
# rekognition = AWS Rekognition (requer credenciais AWS configuradas)
FACE_PROVIDER=none
FACE_MATCH_THRESHOLD=85
