# URL da API do backend Kairos Ponto acessível PELO CELULAR.
# Em dev, use o IP da sua máquina na rede local (não "localhost"), ex:
#   EXPO_PUBLIC_API_URL=http://192.168.0.10:8040/api
# Em produção, a URL pública, ex:
#   EXPO_PUBLIC_API_URL=https://ponto.fbautomacao.space/api
EXPO_PUBLIC_API_URL=http://192.168.0.10:8040/api
