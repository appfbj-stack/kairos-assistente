diff --git a/Dockerfile b/Dockerfile
new file mode 100644
index 0000000..62cf23c
--- /dev/null
+++ b/Dockerfile
@@ -0,0 +1,31 @@
+FROM node:22-alpine AS builder
+WORKDIR /app
+
+COPY package*.json ./
+RUN npm ci
+
+COPY . .
+
+# Kairos build-time vars (VITE_* are baked into the frontend bundle)
+ARG VITE_KAIROS_ADMIN_URL
+ARG VITE_KAIROS_CLIENT_ID
+ARG VITE_APP_SLUG
+ENV VITE_KAIROS_ADMIN_URL=$VITE_KAIROS_ADMIN_URL
+ENV VITE_KAIROS_CLIENT_ID=$VITE_KAIROS_CLIENT_ID
+ENV VITE_APP_SLUG=$VITE_APP_SLUG
+
+RUN npm run build
+
+FROM node:22-alpine
+WORKDIR /app
+
+COPY package*.json ./
+RUN npm ci --only=production
+
+COPY --from=builder /app/dist ./dist
+
+RUN mkdir -p /app/data
+
+EXPOSE 3000
+
+CMD ["node", "dist/server.cjs"]
