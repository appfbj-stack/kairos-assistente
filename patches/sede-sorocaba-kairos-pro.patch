+/**
+ * Endpoint público chamado pelo Kairos Admin para verificar se este app
+ * está online e com o contrato de licença implementado.
+ *
+ * Contrato: GET /api/license/verify?client_id={UUID}&app_slug={slug}
+ */
+const express = require('express');
+const router = express.Router();
+
+const APP_SLUG = process.env.APP_SLUG || 'sede-sorocaba';
+
+router.get('/verify', (req, res) => {
+  res.json({
+    app: 'Sede Sorocaba — Kairos Pro',
+    slug: APP_SLUG,
+    client_id: req.query.client_id || '',
+    online: true,
+  });
+});
+
+module.exports = router;
