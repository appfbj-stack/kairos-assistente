@@ -0,0 +1,35 @@
+/**
+ * Kairos Admin license verification service.
+ *
+ * Calls the Kairos Admin API to check if this app instance has an active
+ * license. If KAIROS_ADMIN_URL or KAIROS_CLIENT_ID are not set, the check
+ * is skipped so local development works without Kairos Admin running.
+ */
+const axios = require('axios');
+
+const APP_SLUG = process.env.APP_SLUG || 'sede-sorocaba';
+
+async function verificarLicenca() {
+  const adminUrl = process.env.KAIROS_ADMIN_URL;
+  const clientId = process.env.KAIROS_CLIENT_ID;
+
+  if (!adminUrl || !clientId) {
+    return { ativa: true, plano: 'unknown', bloqueada: false };
+  }
+
+  const url = `${adminUrl.replace(/\/$/, '')}/api/license/verify?client_id=${clientId}&app_slug=${APP_SLUG}`;
+
+  try {
+    const { data } = await axios.get(url, { timeout: 5000 });
+    return {
+      ativa: data.active !== false,
+      plano: data.plan || 'unknown',
+      bloqueada: data.active === false,
+    };
+  } catch {
+    // Kairos Admin indisponível — fail open
+    return { ativa: true, plano: 'unknown', bloqueada: false };
+  }
+}
+
+module.exports = { verificarLicenca };
