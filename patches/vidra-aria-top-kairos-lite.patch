+import { useEffect, useState, ReactNode } from 'react';
+
+const ADMIN_URL = import.meta.env.VITE_KAIROS_ADMIN_URL?.replace(/\/$/, '') || '';
+const CLIENT_ID = import.meta.env.VITE_KAIROS_CLIENT_ID || '';
+const APP_SLUG = import.meta.env.VITE_APP_SLUG || 'vidra-aria-top';
+
+export default function LicenseGate({ children }: { children: ReactNode }) {
+  const [status, setStatus] = useState<'checking' | 'ok' | 'blocked'>('checking');
+
+  useEffect(() => {
+    if (!ADMIN_URL || !CLIENT_ID) {
+      setStatus('ok');
+      return;
+    }
+    fetch(`${ADMIN_URL}/api/license/verify?client_id=${CLIENT_ID}&app_slug=${APP_SLUG}`)
+      .then(r => r.json())
+      .then(data => setStatus(data.active === false ? 'blocked' : 'ok'))
+      .catch(() => setStatus('ok')); // fail-open
+  }, []);
+
+  if (status === 'checking') {
+    return (
+      <div className="min-h-screen flex items-center justify-center bg-gray-950">
+        <div className="animate-spin rounded-full h-10 w-10 border-4 border-blue-500 border-t-transparent" />
+      </div>
+    );
+  }
+
+  if (status === 'blocked') {
+    return (
+      <div className="min-h-screen flex items-center justify-center bg-gray-950 text-white p-8">
+        <div className="text-center max-w-md">
+          <div className="text-5xl mb-4">🔒</div>
+          <h1 className="text-2xl font-bold mb-2">Acesso Suspenso</h1>
+          <p className="text-gray-400">
+            A licença deste aplicativo está suspensa ou expirada.
+            Entre em contato com o administrador para regularizar.
+          </p>
+        </div>
+      </div>
+    );
+  }
+
+  return <>{children}</>;
+}
