diff --git a/backend/src/routes/cadastro.js b/backend/src/routes/cadastro.js
new file mode 100644
index 0000000..99e07a1
--- /dev/null
+++ b/backend/src/routes/cadastro.js
@@ -0,0 +1,66 @@
+const express = require('express');
+const { v4: uuidv4 } = require('uuid');
+const { getDb } = require('../db/schema');
+
+const router = express.Router();
+
+// Returns congregation public info (no auth)
+router.get('/:slug', (req, res) => {
+  const db = getDb();
+  const cong = db.prepare("SELECT id, nome, cidade, estado FROM congregacoes WHERE id = ? OR nome = ? AND status = 'ativa'")
+    .get(req.params.slug, req.params.slug);
+  if (!cong) return res.status(404).json({ erro: 'Congregação não encontrada' });
+  res.json(cong);
+});
+
+// Public self-registration (no auth) — creates member with status='pendente'
+router.post('/:slug', (req, res) => {
+  const db = getDb();
+  const cong = db.prepare("SELECT id, nome FROM congregacoes WHERE id = ? AND status = 'ativa'")
+    .get(req.params.slug);
+  if (!cong) return res.status(404).json({ erro: 'Congregação não encontrada ou inativa' });
+
+  const { nome, telefone, whatsapp, email, cpf, data_nascimento, endereco, estado_civil, cargo, observacoes } = req.body;
+  if (!nome?.trim()) return res.status(400).json({ erro: 'Nome obrigatório' });
+
+  // Check duplicate by CPF or name
+  if (cpf) {
+    const cpfLimpo = cpf.replace(/\D/g, '');
+    const existe = db.prepare("SELECT id FROM membros WHERE REPLACE(REPLACE(cpf,'.',''),'-','') = ? AND congregacao_id = ?").get(cpfLimpo, cong.id);
+    if (existe) return res.status(409).json({ erro: 'CPF já cadastrado nesta congregação' });
+  }
+
+  const id = uuidv4();
+  const agora = new Date().toISOString();
+  db.prepare(`INSERT INTO membros (id, congregacao_id, nome, telefone, whatsapp, email, cpf, data_nascimento, endereco, estado_civil, cargo, observacoes, status, criado_em, atualizado_em)
+    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'pendente', ?, ?)`)
+    .run(id, cong.id, nome.trim(), telefone||null, whatsapp||null, email||null, cpf||null, data_nascimento||null, endereco||null, estado_civil||null, cargo||null, observacoes||null, agora, agora);
+
+  res.status(201).json({ ok: true, id, congregacao: cong.nome });
+});
+
+// Approve pending member (auth required — added inline)
+router.post('/:congregacao_id/aprovar/:id', (req, res) => {
+  const { autenticar } = require('../middleware/auth');
+  autenticar(req, res, () => {
+    const db = getDb();
+    const m = db.prepare("SELECT * FROM membros WHERE id = ? AND status = 'pendente'").get(req.params.id);
+    if (!m) return res.status(404).json({ erro: 'Membro pendente não encontrado' });
+    db.prepare("UPDATE membros SET status = 'ativo', atualizado_em = ? WHERE id = ?").run(new Date().toISOString(), req.params.id);
+    res.json({ ok: true });
+  });
+});
+
+// Reject pending member
+router.delete('/:congregacao_id/rejeitar/:id', (req, res) => {
+  const { autenticar } = require('../middleware/auth');
+  autenticar(req, res, () => {
+    const db = getDb();
+    const m = db.prepare("SELECT * FROM membros WHERE id = ? AND status = 'pendente'").get(req.params.id);
+    if (!m) return res.status(404).json({ erro: 'Não encontrado' });
+    db.prepare("DELETE FROM membros WHERE id = ?").run(req.params.id);
+    res.json({ ok: true });
+  });
+});
+
+module.exports = router;
