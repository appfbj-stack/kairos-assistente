+"""
+Public endpoint for Kairos Admin health check.
+Contract: GET /api/license/verify?client_id={UUID}&app_slug={slug}
+"""
+from fastapi import APIRouter, Query
+from app.core.config import settings
+
+router = APIRouter(prefix="/api/license", tags=["license"])
+
+
+@router.get("/verify")
+def license_verify(client_id: str = Query(...), app_slug: str = Query(...)):
+    return {
+        "app": "Agenda Mecânica Pro",
+        "slug": settings.APP_SLUG,
+        "client_id": client_id,
+        "online": True,
+    }
diff --git a/backend/app/services/license.py b/backend/app/services/license.py
new file mode 100644
index 0000000..8dfd9c5
--- /dev/null
+++ b/backend/app/services/license.py
@@ -0,0 +1,42 @@
+"""
+Kairos Admin license verification service.
+Fail-open: if KAIROS_ADMIN_URL or KAIROS_CLIENT_ID are not set, the check is skipped.
+"""
+import httpx
+from app.core.config import settings
+
+
+async def verify_license(client_id: str) -> dict:
+    if not settings.KAIROS_ADMIN_URL or not settings.KAIROS_CLIENT_ID:
+        return {"active": True, "plan": "unknown", "blocked": False}
+
+    url = (
+        f"{settings.KAIROS_ADMIN_URL.rstrip('/')}"
+        f"/api/license/verify"
+        f"?client_id={client_id}&app_slug={settings.APP_SLUG}"
+    )
+    try:
+        async with httpx.AsyncClient(timeout=5.0) as client:
+            resp = await client.get(url)
+            if resp.status_code == 200:
+                data = resp.json()
+                return {
+                    "active": data.get("active", True),
+                    "plan": data.get("plan", "unknown"),
+                    "blocked": not data.get("active", True),
+                }
+    except Exception:
+        pass
+
+    return {"active": True, "plan": "unknown", "blocked": False}
+
+
+async def check_tenant_license(tenant_slug: str) -> None:
+    from fastapi import HTTPException
+
+    result = await verify_license(tenant_slug)
+    if result.get("blocked"):
+        raise HTTPException(
+            status_code=403,
+            detail="Licença expirada ou suspensa. Entre em contato com o administrador.",
+        )
